{
  "$schema": "./catalog.schema.json",
  "registryVersion": 1,
  "updated": "2026-07-12",
  "minAppVersion": "0.1.0",
  "entries": [
    {
      "id": "rtk",
      "name": "RTK",
      "plainLabel": "Shrink terminal noise",
      "description": "Compresses command output (git, tests, builds) before Claude reads it",
      "layer": "tool_output",
      "installType": "binary+hook",
      "status": "curated_v1",
      "defaultOn": true,
      "license": "Apache-2.0",
      "source": {
        "type": "github_release",
        "repo": "rtk-ai/rtk",
        "pinnedVersion": "v0.43.0",
        "assets": {
          "darwin-aarch64": "rtk-v0.43.0-aarch64-apple-darwin.tar.gz",
          "darwin-x86_64": "rtk-v0.43.0-x86_64-apple-darwin.tar.gz"
        },
        "checksumFile": "checksums.txt"
      },
      "install": {
        "steps": [
          { "step": "download_release_asset", "verify": "sha256_from_checksum_file" },
          { "step": "extract_binary", "binary": "rtk", "dest": "~/.piggy/bin/rtk" },
          { "step": "merge_hooks", "hooks": {
              "PreToolUse": [
                {
                  "matcher": "Bash",
                  "hooks": [
                    { "type": "command", "command": "~/.piggy/bin/rtk claude-hook", "timeout": 10 }
                  ]
                }
              ]
            },
            "note": "VERIFY-BEFORE-SHIP: M2 must confirm exact hook JSON by running `rtk init -g` against a sandboxed HOME and capturing the settings.json diff; update this pinned shape to match v0.43.0 exactly."
          }
        ]
      },
      "uninstall": {
        "steps": [
          { "step": "remove_hooks", "ownedOnly": true },
          { "step": "delete_file", "path": "~/.piggy/bin/rtk" }
        ]
      },
      "healthCheck": {
        "checks": [
          { "check": "binary_runs", "cmd": ["~/.piggy/bin/rtk", "--version"] },
          { "check": "hook_present", "event": "PreToolUse", "commandContains": "rtk" }
        ]
      },
      "conflictsWith": [],
      "ordering": 10,
      "behaviorChanging": false,
      "claimedSavings": "~80% on shell output (author estimate, TypeScript/Rust projects)",
      "risk": "low",
      "notes": "Hook only intercepts the Bash tool; Read/Grep/Glob untouched. Telemetry opt-in only (RTK_TELEMETRY_DISABLED=1 set by Piggy at install)."
    },
    {
      "id": "caveman",
      "name": "Caveman",
      "plainLabel": "Terse replies",
      "description": "Claude answers in short caveman speak — fewer words, same code",
      "layer": "reply_style",
      "installType": "claude_plugin",
      "status": "curated_v1",
      "defaultOn": false,
      "license": "MIT",
      "source": {
        "type": "claude_plugin_marketplace",
        "repo": "JuliusBrussee/caveman",
        "marketplace": "caveman",
        "plugin": "caveman"
      },
      "install": {
        "steps": [
          { "step": "claude_cli", "args": ["plugin", "marketplace", "add", "JuliusBrussee/caveman"] },
          { "step": "claude_cli", "args": ["plugin", "install", "caveman@caveman"] }
        ]
      },
      "uninstall": {
        "steps": [
          { "step": "claude_cli", "args": ["plugin", "uninstall", "caveman@caveman"] },
          { "step": "claude_cli", "args": ["plugin", "marketplace", "remove", "caveman"], "ignoreFailure": true }
        ]
      },
      "healthCheck": {
        "checks": [
          { "check": "plugin_enabled", "plugin": "caveman@caveman" }
        ]
      },
      "conflictsWith": ["ponytail"],
      "ordering": 50,
      "behaviorChanging": true,
      "warning": "Independent JetBrains A/B test (82–86 tasks) measured ~8.5% real-world savings vs the 65% claim — with no quality loss. Modest but real.",
      "claimedSavings": "65% fewer output tokens (author, chat-only benchmark)",
      "measuredPrior": { "source": "JetBrains SkillsBench A/B, July 2026", "outputTokenDelta": -0.085, "qualityP": 0.82 },
      "risk": "low",
      "notes": "Skill adds ~1–1.5k input tokens per turn (author's own honest caveat). Zero telemetry."
    },
    {
      "id": "ponytail",
      "name": "Ponytail",
      "plainLabel": "Write less code",
      "description": "Nudges Claude to build only what you asked for — no gold-plating",
      "layer": "reply_style",
      "installType": "claude_plugin",
      "status": "curated_v1",
      "defaultOn": false,
      "license": "MIT",
      "source": {
        "type": "claude_plugin_marketplace",
        "repo": "DietrichGebert/ponytail",
        "marketplace": "ponytail",
        "plugin": "ponytail"
      },
      "install": {
        "steps": [
          { "step": "require_binary", "binary": "node", "reason": "lifecycle hooks; degrades to skill-only without it", "soft": true },
          { "step": "claude_cli", "args": ["plugin", "marketplace", "add", "DietrichGebert/ponytail"] },
          { "step": "claude_cli", "args": ["plugin", "install", "ponytail@ponytail"] }
        ]
      },
      "uninstall": {
        "steps": [
          { "step": "run_plugin_script", "script": "scripts/uninstall.js", "runner": "node", "ignoreFailure": true, "note": "must run BEFORE plugin uninstall — cleans ~/.config/ponytail and any statusLine entry" },
          { "step": "claude_cli", "args": ["plugin", "uninstall", "ponytail@ponytail"] },
          { "step": "claude_cli", "args": ["plugin", "marketplace", "remove", "ponytail"], "ignoreFailure": true },
          { "step": "verify_no_setting", "path": "statusLine", "contains": "ponytail" }
        ]
      },
      "healthCheck": {
        "checks": [
          { "check": "plugin_enabled", "plugin": "ponytail@ponytail" }
        ]
      },
      "conflictsWith": ["caveman"],
      "ordering": 60,
      "behaviorChanging": true,
      "warning": "Changes how Claude writes code (less of it). Authors retracted their early 80–94% claim themselves; current honest benchmark: −22% tokens.",
      "claimedSavings": "−22% tokens / −20% cost (author agentic benchmark, n=4)",
      "risk": "low",
      "notes": "Node.js soft dependency. Authors publicly self-corrected inflated benchmarks — good honesty signal."
    },
    {
      "id": "sweep",
      "name": "Sweep",
      "plainLabel": "Clean unused extras",
      "description": "Finds add-ons you never use that cost tokens on every request, and switches them off",
      "layer": "static_config",
      "installType": "builtin",
      "status": "curated_v1",
      "defaultOn": true,
      "license": "MIT",
      "source": { "type": "builtin" },
      "install": { "steps": [{ "step": "builtin_enable", "module": "sweep" }] },
      "uninstall": { "steps": [{ "step": "builtin_disable", "module": "sweep", "restoresDisabledItems": true }] },
      "healthCheck": { "checks": [{ "check": "builtin", "module": "sweep" }] },
      "conflictsWith": [],
      "ordering": 5,
      "behaviorChanging": false,
      "claimedSavings": "depends on your setup (Piggy measures it)",
      "risk": "low",
      "notes": "Piggy's own code. Static-config cleanup only; every disable is one-click reversible."
    },
