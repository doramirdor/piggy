{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/format-guard"
          }
        ]
      }
    ]
  },
  "aFutureFieldPiggyHasNeverSeen": {
    "nested": [1, 2, 3],
    "flag": true
  },
  "outputStyle": "Explanatory",
  "zzz_trailing_unknown": "keep me exactly"
}
